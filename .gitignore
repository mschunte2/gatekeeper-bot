# secrets and per-deployment state
.env
.env.local
key.hex

# Python venv
venv/

# webxdc app build output and JS deps. apps/*/ are live sources;
# apps-disabled/*/ holds sources of apps currently unpublished. The
# built .xdc artefacts (under apps/ for live, apps-disabled/ for
# disabled) ARE tracked.
apps/*/node_modules/
apps/*/dist/
apps-disabled/*/node_modules/
apps-disabled/*/dist/

# local bluepy build (checked out via pip install -e for the fast path)
bluepy/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# editor scratch
*.swp
*~

# captured BLE logs if you ever run with --verbose | tee
log-*.log
log.txt

# retired apps -- kept in history but not reintroduced into new builds
quick-unlock/
quick-unlock.xdc
.claude/
