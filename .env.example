# Copy this file to .env and fill in the real values.
# .env is gitignored so it never enters the public repo.

# Lock identity
LOCK_MAC=00:AA:BB:CC:DD:EE
USER_ID=1
USER_KEY=01234567890123456789012345678901

# Used only by register-user.sh.
# QR_DATA encodes the lock MAC, the factory card-key, and a serial.
# Format: M<12-hex-MAC>K<32-hex-card-key><10-char-serial>
QR_DATA=M00CAFFEEDEADK00112233445566778899aabbccddeeff00SERIAL1234
USER_NAME=mybot

# BLE link parameters.
HCI_IFACE=1
SEC_LEVEL=medium
CONNECT_TIMEOUT=75
TIMEOUT=90

# Comma-separated list of DeltaChat chat ids allowed to operate the lock.
# This list gates BOTH text commands (/lock, /unlock, /status) AND the
# webxdc app (chats in this list automatically receive the app).
ALLOWED_CHATS=

# Display name shown as the heading inside the webxdc app.
DOOR_NAME="Some Door"

# Optional help message shown when users send an unknown command.
# Unset or empty => a sensible English default is used.
# Multi-line values are supported; bash `source` handles the quoting.
# Example:
HELP_MESSAGE="This bot operates a lock:
    /lock or /zu - locks gate
    /unlock or /auf - unlocks gate
    /status - current status
    /apps - (re)send the webxdc control apps (Gatekeeper + Quick-Unlock + Quick-Lock)
    /id - get ID of the chat"
#    PROBLEMS? Call Alice +1-555-1234."
